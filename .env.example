# Tray On — environment contract. Mirrors ARCHITECTURE.md "Env contract".
# Production runs on Railway: pgsql + redis, three services (web/worker/scheduler).
# The predeploy guard (trayon:predeploy-check) fails closed on missing critical keys.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Tray On"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Public HTTPS URL in prod. Drives secure cookies, signed-URL base, widget origin.
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Tenancy encryption ────────────────────────────────────────────────────────
# Base64 32-byte key, SEPARATE from APP_KEY so per-site credential encryption
# (widget_secret) can be rotated without invalidating sessions. Generate a fresh
# value with: php artisan key:generate --show
TENANT_CREDENTIALS_KEY=

# ── Database (Postgres in prod; sqlite locally) ───────────────────────────────
# Railway injects DATABASE_URL. Fallback chain: DB_URL -> DATABASE_URL ->
# DB_HOST/DB_PORT/DB_DATABASE/DB_USERNAME/DB_PASSWORD -> PGHOST/PGPORT/PG*.
# NEVER sqlite in production — ephemeral fs loses every ledger row on restart.
DB_CONNECTION=pgsql
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=trayon
DB_USERNAME=postgres
DB_PASSWORD=

# ── Cache / Queue / Session (CRITICAL on Railway — never `file`/`array`) ───────
# Horizon, locks, the heartbeat and the widget rate-limiters all require Redis.
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Railway injects REDIS_URL. Fallback: REDIS_URL -> REDIS_HOST/REDIS_PORT/REDIS_PASSWORD.
REDIS_URL=
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
# retry_after MUST exceed the longest job timeout (GEN_TIMEOUT=70) — keep >= 120.
REDIS_QUEUE_RETRY_AFTER=120

# ── Horizon ───────────────────────────────────────────────────────────────────
# Namespaces Horizon's Redis keys so multiple apps can share one Redis.
HORIZON_PREFIX=trayon_horizon

# ── OpenRouter (platform AI provider — server-side only, NEVER in the browser) ─
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Must comfortably fit the slowest image generation but stay <= the job timeout.
OPENROUTER_TIMEOUT=80
OPENROUTER_HTTP_REFERER="${APP_URL}"
OPENROUTER_APP_TITLE="${APP_NAME}"

# ── Media (S3-compatible disk behind a CDN; short signed-URL TTL) ─────────────
# Reads go through the CDN (cheap edge egress), not the origin bucket. R2 needs a
# custom endpoint + path-style. Creds fall back S3_* -> R2_* -> AWS_*.
MEDIA_DISK=s3
MEDIA_CDN_URL=
MEDIA_SIGNED_TTL=600
S3_KEY=
S3_SECRET=
S3_REGION=auto
S3_BUCKET=
S3_ENDPOINT=
S3_USE_PATH_STYLE_ENDPOINT=true
# R2 aliases (optional — used if S3_* are unset).
R2_KEY=
R2_SECRET=
R2_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_USE_PATH_STYLE_ENDPOINT=true

# ── Credit purchase rail — LOCKED to PayPlus for v1 ───────────────────────────
# Behind the CreditPaymentProvider interface so a future rail is swappable.
# (Per-site widget_secret is NEVER here — it is encrypted in the DB.)
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_PAGE_UID=
PAYPLUS_BASE_URL=https://restapi.payplus.co.il/api/v1.0
PAYPLUS_WEBHOOK_SECRET=
# Charge currency (USD default; ILS is the Q1-open decision). Timeout in seconds.
PAYPLUS_CURRENCY=USD
PAYPLUS_TIMEOUT=30

# ── Pricing ───────────────────────────────────────────────────────────────────
CREDIT_MARKUP_DEFAULT=2.5
CREDIT_OPENING_GRANT_USD=5

# ── Usage limits (saas-credits-billing numbers; railway-infra owns the Redis bucket) ──
# Per-(account,site) widget generations/min, and a per-account generations/min ceiling.
USAGE_SITE_WIDGET_RPM=20
USAGE_ACCOUNT_GEN_RPM=120

# ── PDP fetch/render (pdp-scanner, Phase 4) ────────────────────────────────────
# HTTP-first; escalates to the headless render sidecar (railway-infra hosts it)
# on a JS-heavy / SPA PDP when SCRAPER_RENDER_ENABLED=true.
SCRAPER_DRIVER=http
SCRAPER_SERVICE_URL=
SCRAPER_SERVICE_TOKEN=
SCRAPER_RENDER_ENABLED=false
SCRAPER_USER_AGENT="TrayOnBot/1.0 (+https://trayon.app/bot)"
SCRAPER_HTTP_TIMEOUT=15
SCRAPER_RENDER_TIMEOUT=30
SCRAPER_MAX_BYTES=3145728
SCRAPER_RESPECT_ROBOTS=true
SCRAPER_MAX_REDIRECTS=5
# Legacy stub keys (Phase 2) — kept for back-compat.
SCRAPER_BASE_URL=
SCRAPER_API_KEY=
SCRAPER_TIMEOUT=30

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
