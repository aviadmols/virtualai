# FrankPHP / Caddy site config for the web service.
# Railway provides $PORT; FrankPHP serves the Laravel public/ dir.
{
	frankenphp
	# Disable the Caddy admin endpoint in production.
	admin off
	# Trust Railway's proxy so APP_URL / HTTPS detection works behind the edge
	# (secure cookies, the widget's Origin checks, and signed-URL generation all
	# depend on the request being seen as HTTPS).
	servers {
		trusted_proxies static private_ranges
	}
	log {
		output stdout
		format console
	}
}

:{$PORT:8080} {
	root * public/
	encode zstd gzip

	# Long-cache FINGERPRINTED local assets (Filament build — hashed filenames).
	# The widget loader is excluded: it lives at a STABLE, unhashed URL
	# (/widget/v1/widget.js) embedded on merchant stores, so it must NOT be immutable
	# or a bug fix would never reach shoppers. Try-on images come from the CDN, not here.
	@static {
		path *.css *.js *.svg *.png *.jpg *.jpeg *.gif *.ico *.woff *.woff2 *.ttf
		not path /widget/v1/*
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# The embedded widget loader: short cache + revalidate so fixes propagate fast
	# (the per-site config the widget needs is fetched live via /widget/v1/bootstrap).
	@widget path /widget/v1/*
	header @widget Cache-Control "public, max-age=300, must-revalidate"

	php_server
}
